ARG_MIDDLE_100="-94 -97 -218 -288 -7 -296 -299 -32 -304 -171 -35 -323 -352 -360 -201 -382 -425 -454 -52 -455 -307 -463 -55 -337 -376 171 -380 -420 -16 -437 -481 58 -99 -123 -132 -488 137 -138 -161 -241 -424 303 219 32 226 -249 -442 166 25 -275 296 -166 -279 -283 277 157 -332 419 213 113 -36 82 56 354 -46 500 149 65 497 -51 -63 484 -190 451 278 53 459 9 -66 433 416 269 223 400 383 -20 -100 377 322 141 -34 257 312 167 273 245 242 155 151 62"
middle: $(NAME)
	./push_swap --medium $(ARG_MIDDLE_100)

middle_check: $(NAME)
ifeq ($(shell uname), Darwin)
	./$(NAME) --medium $(ARG_MIDDLE_100) | ./checker/checker_Mac $(ARG_MIDDLE_100)
endif
ifeq ($(OS), Linux)
	./$(NAME) --medium $(ARG_MIDDLE_100) | ./checker/checker_linux $(ARG_MIDDLE_100)
endif

as: $(ASSERT_OBJS)
	$(CC) $(CFLAGS) $(ASSERT_OBJS) -Llib -lft -o $(NAME_ASSER)
ifeq ($(shell uname), Darwin)
#/* @leaks -q  -atExit -- 
	@./$(NAME_ASSER) $(ARG)
endif
ifeq ($(OS), Linux)
	valgrind --leak-check=full  --leak-resolution=high --log-file=$(VALGRIND_LOG) ./$(NAME_ASSER) $(ARG)
endif

clean:
	make clean -C $(LIBFT)
	rm -rf $(SRCS_OBJS) $(ASSERT_OBJS) $(VALGRIND_LOG)

fclean: clean
	rm -rf $(NAME) $(NAME_ASSER)

re: fclean $(NAME)

COM=push_swap_generic

git: fclean
	git add .
	git commit -m $(COM)
	git push origin $(shell git branch --show-current)

libft:
	make -C $(LIBFT)

.PHONY: all clean fclean re as home libft git lldb middle simple